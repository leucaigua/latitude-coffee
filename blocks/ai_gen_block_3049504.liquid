{% doc %}
  @prompt
    If at least one variant is on sale, add the sale badge.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign has_sale = false
  for variant in product.variants
    if variant.compare_at_price > variant.price
      assign has_sale = true
      break
    endif
  endfor
%}

{% if has_sale %}
  {% style %}
    .ai-sale-badge-{{ ai_gen_id }} {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
      background-color: {{ block.settings.badge_background }};
      color: {{ block.settings.badge_text_color }};
      border-radius: {{ block.settings.border_radius }}px;
      font-size: {{ block.settings.font_size }}px;
      font-weight: {{ block.settings.font_weight }};
      text-transform: {{ block.settings.text_transform }};
      letter-spacing: 0.5px;
    }
  {% endstyle %}

  <div class="ai-sale-badge-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    {{ block.settings.badge_text }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Sale badge",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Sale"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Background color",
      "default": "#dea63d"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#371c11"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 2,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Vertical padding",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Sale badge"
    }
  ]
}
{% endschema %}

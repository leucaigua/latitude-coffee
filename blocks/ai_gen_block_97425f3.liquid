{% doc %}
  @prompt
    Full-width section with a large heading and a short descriptive paragraph centered at the top.
    
    
    Below the text, show a horizontal row of filter tabs (pills) that the user can click.
    
    
    Tabs / filters behavior:
    
    
    Each tab represents a pre-selected collection.
    
    
    When a tab is clicked, the products from that collection are shown in a horizontal product carousel.
    
    
    Include a default “All” tab that shows products from all chosen collections.
    
    
    Carousel behavior:
    
    
    On desktop: show 4 products per view with arrows and dots to navigate.
    
    
    On tablet: show 2–3 products per view.
    
    
    On mobile: show 1–2 products per view with swipe support.
    
    
    Option to limit how many products are loaded from each collection (e.g., 8–12).
    
    
    
    Customization settings in the section schema:
    
    
    Heading text
    
    
    Subheading / description text
    
    
    Background color and padding controls
    
    
    Text alignment (center / left)
    
    
    List of up to 6 collections to use as tabs (each tab label should be editable, e.g., “All, Signature Blends, Origins, Organics, Espresso Blends, Flavored, Decaf”).
    
    
    Product limit per tab
    
    
    Option to enable/disable autoplay for the carousel.
    
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-tabs-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-collection-tabs__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-tabs__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-collection-tabs__heading-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    margin: 0 0 16px;
    color: {{ block.settings.heading_color }};
  }

  .ai-collection-tabs__description-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-collection-tabs__tabs-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-collection-tabs__tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    border: 1px solid {{ block.settings.tab_border_color }};
    background-color: {{ block.settings.tab_background }};
    color: {{ block.settings.tab_text_color }};
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 14px;
    font-weight: 500;
  }

  .ai-collection-tabs__tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_background }};
    border-color: {{ block.settings.tab_hover_border }};
    color: {{ block.settings.tab_hover_text }};
  }

  .ai-collection-tabs__tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_background }};
    border-color: {{ block.settings.tab_active_border }};
    color: {{ block.settings.tab_active_text }};
  }

  .ai-collection-tabs__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-collection-tabs__carousel-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-collection-tabs__carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    gap: 20px;
  }

  .ai-collection-tabs__product-{{ ai_gen_id }} {
    flex: 0 0 calc(25% - 15px);
    min-width: 0;
  }

  .ai-collection-tabs__product-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-tabs__product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .ai-collection-tabs__product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-tabs__product-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-tabs__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-tabs__nav-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_background }};
    border: 1px solid {{ block.settings.arrow_border }};
    color: {{ block.settings.arrow_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.3s ease;
  }

  .ai-collection-tabs__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-collection-tabs__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-tabs__nav-button--prev-{{ ai_gen_id }} {
    left: -24px;
  }

  .ai-collection-tabs__nav-button--next-{{ ai_gen_id }} {
    right: -24px;
  }

  .ai-collection-tabs__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }

  .ai-collection-tabs__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .ai-collection-tabs__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    width: 24px;
    border-radius: 4px;
  }

  .ai-collection-tabs__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-collection-tabs__product-{{ ai_gen_id }} {
      flex: 0 0 calc(33.333% - 14px);
    }

    .ai-collection-tabs__heading-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-collection-tabs__nav-button--prev-{{ ai_gen_id }} {
      left: 0;
    }

    .ai-collection-tabs__nav-button--next-{{ ai_gen_id }} {
      right: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-tabs__product-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 10px);
    }

    .ai-collection-tabs__heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-collection-tabs__tabs-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-collection-tabs__nav-button-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }
  }
{% endstyle %}

<collection-tabs-carousel-{{ ai_gen_id }}
  class="ai-collection-tabs-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay_enabled }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-tabs__container-{{ ai_gen_id }}">
    <div class="ai-collection-tabs__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-collection-tabs__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <p class="ai-collection-tabs__description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
      {% endif %}
    </div>

    <div class="ai-collection-tabs__tabs-{{ ai_gen_id }}">
      <button
        class="ai-collection-tabs__tab-{{ ai_gen_id }} active"
        data-tab="all"
      >
        {{ block.settings.all_tab_label }}
      </button>

      {% for i in (1..6) %}
        {% assign collection_key = 'collection_' | append: i %}
        {% assign label_key = 'collection_' | append: i | append: '_label' %}
        {% assign collection = block.settings[collection_key] %}
        {% assign label = block.settings[label_key] %}

        {% if collection != blank and label != blank %}
          <button
            class="ai-collection-tabs__tab-{{ ai_gen_id }}"
            data-tab="collection-{{ i }}"
            data-collection-handle="{{ collection.handle }}"
          >
            {{ label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-collection-tabs__carousel-wrapper-{{ ai_gen_id }}">
      <button
        class="ai-collection-tabs__nav-button-{{ ai_gen_id }} ai-collection-tabs__nav-button--prev-{{ ai_gen_id }}"
        aria-label="Previous products"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-collection-tabs__carousel-{{ ai_gen_id }}">
        <div class="ai-collection-tabs__carousel-track-{{ ai_gen_id }}" data-tab-content="all">
          {% assign all_products = '' %}
          {% assign product_limit = block.settings.product_limit %}

          {% for i in (1..6) %}
            {% assign collection_key = 'collection_' | append: i %}
            {% assign collection = block.settings[collection_key] %}

            {% if collection != blank %}
              {% for product in collection.products limit: product_limit %}
                {% assign product_id_str = product.id | append: '' %}
                {% unless all_products contains product_id_str %}
                  {% assign all_products = all_products | append: product_id_str | append: ',' %}
                  <div class="ai-collection-tabs__product-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-collection-tabs__product-card-{{ ai_gen_id }}">
                      <div class="ai-collection-tabs__product-image-wrapper-{{ ai_gen_id }}">
                        {% if product.featured_image %}
                          <img
                            src="{{ product.featured_image | image_url: width: 600 }}"
                            alt="{{ product.featured_image.alt | escape }}"
                            class="ai-collection-tabs__product-image-{{ ai_gen_id }}"
                            loading="lazy"
                            width="600"
                            height="600"
                          >
                        {% else %}
                          <div class="ai-collection-tabs__product-image-placeholder-{{ ai_gen_id }}">
                            {{ 'product-1' | placeholder_svg_tag }}
                          </div>
                        {% endif %}
                      </div>
                      <h3 class="ai-collection-tabs__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                      <div class="ai-collection-tabs__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                    </a>
                  </div>
                {% endunless %}
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>

        {% for i in (1..6) %}
          {% assign collection_key = 'collection_' | append: i %}
          {% assign collection = block.settings[collection_key] %}

          {% if collection != blank %}
            <div
              class="ai-collection-tabs__carousel-track-{{ ai_gen_id }}"
              data-tab-content="collection-{{ i }}"
              style="display: none;"
            >
              {% for product in collection.products limit: block.settings.product_limit %}
                <div class="ai-collection-tabs__product-{{ ai_gen_id }}">
                  <a href="{{ product.url }}" class="ai-collection-tabs__product-card-{{ ai_gen_id }}">
                    <div class="ai-collection-tabs__product-image-wrapper-{{ ai_gen_id }}">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          class="ai-collection-tabs__product-image-{{ ai_gen_id }}"
                          loading="lazy"
                          width="600"
                          height="600"
                        >
                      {% else %}
                        <div class="ai-collection-tabs__product-image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>
                    <h3 class="ai-collection-tabs__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <div class="ai-collection-tabs__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                  </a>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <button
        class="ai-collection-tabs__nav-button-{{ ai_gen_id }} ai-collection-tabs__nav-button--next-{{ ai_gen_id }}"
        aria-label="Next products"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <div class="ai-collection-tabs__dots-{{ ai_gen_id }}"></div>
  </div>
</collection-tabs-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionTabsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.currentTab = 'all';
        this.autoplayInterval = null;
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-collection-tabs__tab-{{ ai_gen_id }}');
        this.carousel = this.querySelector('.ai-collection-tabs__carousel-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-tabs__nav-button--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-tabs__nav-button--next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-collection-tabs__dots-{{ ai_gen_id }}');
        this.autoplayEnabled = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        this.setupEventListeners();
        this.updateCarousel();
        this.createDots();

        if (this.autoplayEnabled) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            this.switchTab(tab.dataset.tab);
          });
        });

        this.prevButton.addEventListener('click', () => {
          this.navigate(-1);
        });

        this.nextButton.addEventListener('click', () => {
          this.navigate(1);
        });

        this.carousel.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.carousel.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        if (this.autoplayEnabled) {
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }
      }

      switchTab(tabName) {
        this.tabs.forEach(tab => {
          tab.classList.toggle('active', tab.dataset.tab === tabName);
        });

        const allTracks = this.querySelectorAll('.ai-collection-tabs__carousel-track-{{ ai_gen_id }}');
        allTracks.forEach(track => {
          track.style.display = track.dataset.tabContent === tabName ? 'flex' : 'none';
        });

        this.currentTab = tabName;
        this.currentIndex = 0;
        this.updateCarousel();
        this.createDots();
      }

      navigate(direction) {
        const track = this.querySelector(`[data-tab-content="${this.currentTab}"]`);
        const products = track.querySelectorAll('.ai-collection-tabs__product-{{ ai_gen_id }}');
        const slidesToShow = this.getSlidesToShow();
        const maxIndex = Math.max(0, Math.ceil(products.length / slidesToShow) - 1);

        this.currentIndex = Math.max(0, Math.min(this.currentIndex + direction, maxIndex));
        this.updateCarousel();

        if (this.autoplayEnabled) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      updateCarousel() {
        const track = this.querySelector(`[data-tab-content="${this.currentTab}"]`);
        if (!track) return;

        const products = track.querySelectorAll('.ai-collection-tabs__product-{{ ai_gen_id }}');
        const slidesToShow = this.getSlidesToShow();
        const maxIndex = Math.max(0, Math.ceil(products.length / slidesToShow) - 1);

        const slideWidth = 100 / slidesToShow;
        const offset = -this.currentIndex * 100;
        track.style.transform = `translateX(${offset}%)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;

        this.updateDots();
      }

      getSlidesToShow() {
        if (window.innerWidth <= 749) {
          return 2;
        } else if (window.innerWidth <= 989) {
          return 3;
        }
        return 4;
      }

      createDots() {
        const track = this.querySelector(`[data-tab-content="${this.currentTab}"]`);
        if (!track) return;

        const products = track.querySelectorAll('.ai-collection-tabs__product-{{ ai_gen_id }}');
        const slidesToShow = this.getSlidesToShow();
        const dotsCount = Math.ceil(products.length / slidesToShow);

        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < dotsCount; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-collection-tabs__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }

        this.updateDots();
      }

      updateDots() {
        const dots = this.dotsContainer.querySelectorAll('.ai-collection-tabs__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentIndex);
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.navigate(1);
          } else {
            this.navigate(-1);
          }
        }
      }

      startAutoplay() {
        if (!this.autoplayEnabled) return;

        this.autoplayInterval = setInterval(() => {
          const track = this.querySelector(`[data-tab-content="${this.currentTab}"]`);
          const products = track.querySelectorAll('.ai-collection-tabs__product-{{ ai_gen_id }}');
          const slidesToShow = this.getSlidesToShow();
          const maxIndex = Math.max(0, Math.ceil(products.length / slidesToShow) - 1);

          if (this.currentIndex >= maxIndex) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateCarousel();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('collection-tabs-carousel-{{ ai_gen_id }}', CollectionTabsCarousel{{ ai_gen_id }});

    window.addEventListener('resize', () => {
      const carousel = document.querySelector('collection-tabs-carousel-{{ ai_gen_id }}');
      if (carousel) {
        carousel.updateCarousel();
        carousel.createDots();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Collection tabs carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our curated collections of premium coffee and tea"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "text",
      "id": "all_tab_label",
      "label": "All tab label",
      "default": "All"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    },
    {
      "type": "text",
      "id": "collection_1_label",
      "label": "Collection 1 label",
      "default": "Signature Blends"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2"
    },
    {
      "type": "text",
      "id": "collection_2_label",
      "label": "Collection 2 label",
      "default": "Origins"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Collection 3"
    },
    {
      "type": "text",
      "id": "collection_3_label",
      "label": "Collection 3 label",
      "default": "Organics"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Collection 4"
    },
    {
      "type": "text",
      "id": "collection_4_label",
      "label": "Collection 4 label",
      "default": "Espresso Blends"
    },
    {
      "type": "collection",
      "id": "collection_5",
      "label": "Collection 5"
    },
    {
      "type": "text",
      "id": "collection_5_label",
      "label": "Collection 5 label",
      "default": "Flavored"
    },
    {
      "type": "collection",
      "id": "collection_6",
      "label": "Collection 6"
    },
    {
      "type": "text",
      "id": "collection_6_label",
      "label": "Collection 6 label",
      "default": "Decaf"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 20,
      "step": 2,
      "label": "Products per collection",
      "default": 12
    },
    {
      "type": "header",
      "content": "Carousel settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay_enabled",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Tab style"
    },
    {
      "type": "color",
      "id": "tab_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "Border",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "tab_hover_background",
      "label": "Hover background",
      "default": "#f5f5f5"

{% doc %}
  @prompt
    generate breadcrumb
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-breadcrumb-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-breadcrumb-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-breadcrumb-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ block.settings.spacing }}px;
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-breadcrumb-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-breadcrumb-current-{{ ai_gen_id }} {
    color: {{ block.settings.current_color }};
  }

  .ai-breadcrumb-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    user-select: none;
  }

  .ai-breadcrumb-home-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: inline-block;
    vertical-align: middle;
  }

  .ai-breadcrumb-home-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  @media screen and (max-width: 749px) {
    .ai-breadcrumb-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-breadcrumb-nav-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<breadcrumb-navigation-{{ ai_gen_id }} class="ai-breadcrumb-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-breadcrumb-container-{{ ai_gen_id }}">
    <nav class="ai-breadcrumb-nav-{{ ai_gen_id }}" aria-label="Breadcrumb">
      <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
        <a href="/" class="ai-breadcrumb-link-{{ ai_gen_id }}" aria-label="Home">
          {% if block.settings.show_home_icon %}
            <span class="ai-breadcrumb-home-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </span>
          {% else %}
            {{ block.settings.home_text }}
          {% endif %}
        </a>
      </div>

      {% if template.name == 'product' and product %}
        {% if collection %}
          <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
          <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ collection.title }}</a>
          </div>
        {% endif %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ product.title }}</span>
        </div>

      {% elsif template.name == 'collection' and collection %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ collection.title }}</span>
        </div>

      {% elsif template.name == 'page' and page %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ page.title }}</span>
        </div>

      {% elsif template.name == 'blog' and blog %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ blog.title }}</span>
        </div>

      {% elsif template.name == 'article' and article %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <a href="{{ blog.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ blog.title }}</a>
        </div>
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ article.title }}</span>
        </div>

      {% elsif template.name == 'search' %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">Search</span>
        </div>

      {% elsif template.name == 'cart' %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">Cart</span>
        </div>

      {% elsif template.name == 'account' %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">Account</span>
        </div>

      {% elsif template.name == '404' %}
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">Page not found</span>
        </div>
      {% endif %}
    </nav>
  </div>
</breadcrumb-navigation-{{ ai_gen_id }}>

<script>
  (function() {
    class BreadcrumbNavigation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupStructuredData();
      }

      setupStructuredData() {
        const breadcrumbItems = this.querySelectorAll('.ai-breadcrumb-item-{{ ai_gen_id }}');
        if (breadcrumbItems.length === 0) return;

        const itemListElement = Array.from(breadcrumbItems).map((item, index) => {
          const link = item.querySelector('.ai-breadcrumb-link-{{ ai_gen_id }}');
          const current = item.querySelector('.ai-breadcrumb-current-{{ ai_gen_id }}');
          
          if (link) {
            return {
              '@type': 'ListItem',
              'position': index + 1,
              'name': link.textContent.trim(),
              'item': link.href
            };
          } else if (current) {
            return {
              '@type': 'ListItem',
              'position': index + 1,
              'name': current.textContent.trim()
            };
          }
        }).filter(Boolean);

        if (itemListElement.length > 0) {
          const structuredData = {
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            'itemListElement': itemListElement
          };

          const script = document.createElement('script');
          script.type = 'application/ld+json';
          script.textContent = JSON.stringify(structuredData);
          this.appendChild(script);
        }
      }
    }

    customElements.define('breadcrumb-navigation-{{ ai_gen_id }}', BreadcrumbNavigation{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Breadcrumb",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Home link"
    },
    {
      "type": "checkbox",
      "id": "show_home_icon",
      "label": "Show home icon",
      "default": true
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Spacing",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1c0200"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#371c11"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#dea63d"
    },
    {
      "type": "color",
      "id": "current_color",
      "label": "Current page",
      "default": "#1c0200"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#1c0200"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}
